# ---- OSCAR Automation Service configuration ----
# Copy to ".env" and adjust. All values are optional; defaults shown.

# Port the service listens on.
PORT=8787

# Comma-separated list of allowed browser origins (the frontend URL).
# Leave blank in local development to reflect any origin.
# Example for production: https://parharsaacportal.ca
CORS_ORIGINS=

# Run Chromium headless (true) or visible (false). Headless is correct for a
# server / background agent. Set false only for local debugging of OSCAR pages.
PLAYWRIGHT_HEADLESS=true

# Which browser Playwright drives:
#   chromium -> Playwright's bundled Chromium (run `npm run install:browser` once)
#   chrome   -> the system-installed Google Chrome (no download needed)
BROWSER_CHANNEL=chromium

# Close an authenticated OSCAR session after this many minutes of inactivity.
# The user must reconnect (re-enter credentials) afterwards. Credentials are
# never stored, so this is the only "logout" mechanism besides explicit logout.
SESSION_IDLE_MINUTES=20

# Navigation/selector timeout in milliseconds for OSCAR pages.
OSCAR_TIMEOUT_MS=30000

# Optional: prefill the OSCAR login URL shown to operators (frontend may read
# this via its own env; the service does not require it).
# OSCAR_DEFAULT_URL=https://welcome.kai-oscar.com/kaiemr/
