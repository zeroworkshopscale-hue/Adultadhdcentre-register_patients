{
  "name": "oscar-automation-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-automation backend that drives the OSCAR EMR web UI (login + patient search by email) for the ADHD intake dashboard.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "install:browser": "playwright install chromium"
  },
  "dependencies": {
    "@kenjiuno/msgreader": "^1.28.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "playwright": "^1.49.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.16.5",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
