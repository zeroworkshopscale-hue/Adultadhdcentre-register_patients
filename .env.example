# ---- Frontend (Vite) configuration ----
# Copy to ".env" (or ".env.local") at the repo root.

# URL of the OSCAR automation backend (server/). In local dev this is the
# service started by `cd server && npm run dev`.
VITE_OSCAR_SERVICE_URL=http://localhost:8787

# Optional: prefill the OSCAR login URL shown in the Connect panel so operators
# don't have to type it each time.
# VITE_OSCAR_DEFAULT_URL=https://welcome.kai-oscar.com/kaiemr/
